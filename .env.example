# MongoDB Configuration
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DATABASE=government_procurement
MONGO_USERNAME=admin
MONGO_PASSWORD=changeme_secure_password
COLLECTION_NAME=purchase_orders

# MongoDB Initialization
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changeme_secure_password

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# CSV Import Configuration
CSV_FILE_PATH=/data/purchase_orders_2012_2015.csv
BATCH_SIZE=5000
LOG_LEVEL=INFO

# OpenAI API Configuration (REQUIRED for AI Agent)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Web/API Integration
API_REQUEST_TIMEOUT=180

# Model Configuration (Optional)
# Default: gpt-5.2 (latest model with 400K context, 128K output)
# Options: gpt-5.2, gpt-5.2-pro, gpt-5.1, gpt-5, gpt-4o
# OPENAI_MODEL=gpt-5.2

# Reasoning Effort (Optional) - Controls how much the model "thinks"
# Options: minimal, low, medium (default), high, xhigh (new in 5.2)
# REASONING_EFFORT=medium
